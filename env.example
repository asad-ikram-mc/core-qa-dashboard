# CORE QA Dashboard — Environment Variables
# Copy to .env and fill in values, or export directly.
#
# For local development (uses AWS CLI profile):
AWS_PROFILE=your-profile

# For GitHub Actions (uses IAM credentials directly):
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-west-2

# S3 bucket (optional — defaults to wikitablescrapexample)
# S3_BUCKET=wikitablescrapexample

# PostgreSQL database
DB_HOST=your-rds-host.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
